vjust=2, margin = margin(b = 10)),
plot.subtitle = element_text(size = 12, color = "black", hjust = 0.5,
margin = margin(b = 12)),
plot.caption = element_text(size = 10, margin = margin(t = 10), color =
"black", hjust = 0)
)
}
